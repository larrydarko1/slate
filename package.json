{
    "name": "slate",
    "private": true,
    "version": "1.2.9",
    "type": "module",
    "main": "out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "vue-tsc -b && electron-vite build",
        "build:electron": "npm run build && electron-builder",
        "build:mac": "npm run build && electron-builder --mac --publish never",
        "build:win": "npm run build && electron-builder --win --publish never",
        "build:linux": "npm run build && electron-builder --linux --publish never",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "format": "prettier --write \"src/**/*.{ts,vue,scss,json}\"",
        "format:check": "prettier --check \"src/**/*.{ts,vue,scss,json}\"",
        "prepare": "husky",
        "ci:check": "npm run lint && npm run format:check && npm test && npm run build"
    },
    "dependencies": {
        "chart.js": "^4.5.1",
        "vue": "^3.5.17",
        "vue-chartjs": "^5.3.3"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^10.0.1",
        "@types/node": "^24.0.13",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.7.0",
        "electron": "^40.0.0",
        "electron-builder": "^26.4.0",
        "electron-vite": "^5.0.0",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jsdom": "^26.1.0",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "sass-embedded": "^1.92.1",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.57.0",
        "vite": "^7.0.0",
        "vitest": "^3.2.4",
        "vue-tsc": "^2.2.10"
    },
    "description": "A free, canvas-based spreadsheet app for desktop.",
    "author": "Lorenzo Mazzola",
    "license": "MIT",
    "lint-staged": {
        "*.{ts,vue}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{scss,json,md}": [
            "prettier --write"
        ]
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/larrydarko1/slate.git"
    },
    "build": {
        "appId": "com.slate.app",
        "productName": "Slate",
        "directories": {
            "output": "dist-electron"
        },
        "fileAssociations": [
            {
                "ext": "slate",
                "name": "Slate Spreadsheet",
                "description": "Slate Spreadsheet File",
                "mimeType": "application/x-slate",
                "role": "Editor",
                "icon": "build/slate"
            }
        ],
        "files": [
            "out/**/*",
            "node_modules/**/*"
        ],
        "dmg": {
            "background": "build/dmg-background.png",
            "icon": "build/icon.icns",
            "iconSize": 100,
            "iconTextSize": 14,
            "title": "${productName} ${version}",
            "window": {
                "width": 660,
                "height": 400
            },
            "contents": [
                {
                    "x": 180,
                    "y": 260
                },
                {
                    "x": 480,
                    "y": 260,
                    "type": "link",
                    "path": "/Applications"
                }
            ]
        },
        "mac": {
            "category": "public.app-category.productivity",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "arm64",
                        "x64"
                    ]
                }
            ],
            "icon": "build/icon.icns"
        },
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "build/icon.ico"
        },
        "linux": {
            "target": [
                "AppImage"
            ],
            "category": "Utility"
        }
    }
}
